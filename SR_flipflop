
input clk,s,r;
output reg q;
always@(posedge clk)
begin
if(s && !r) begin
q = 1'b1;
end else if(!s && r) 
begin
q = 1'b0;
end else if (!s && !r)
begin
q = q;
end else begin
q = 1'bx;
end
end


